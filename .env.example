# Copy to .env and fill in values (never commit .env)

PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

JWT_SECRET=
DATABASE_URL=

# Google Gemini (AI quiz generation & explanations)
GEMINI_API_KEY="AIzaSyBT-hv_0wLA5_R16jyB8FO8ZlxJjZbXNh4"
# Omit or set to auto/latest — server picks newest gemini-*-flash from Google models.list
# Or set explicitly e.g. gemini-2.5-flash
# GEMINI_MODEL=auto
# Optional: UUID of an existing mst_users row. When set, POST /generate-questions without Bearer
# still saves rows so GET /api/ai-gemini/generations lists them for everyone.
# AI_PUBLIC_GENERATION_OWNER_USER_ID=
# In production, set true to print full generated questions JSON in server logs (default off in prod).
# AI_LOG_GENERATED_QUESTIONS=true

# Admin dashboard: no JWT for GET /api/admin/dashboard when true, or when NODE_ENV=development (default).
# If NODE_ENV=production locally and you still get 401, set:
# ADMIN_DASHBOARD_OPEN=true
